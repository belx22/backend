# ─────────────────────────────────────────────────────────────
# Configuration backend (Spring Boot) — variables d'environnement.
# Utilisees telles quelles par docker-compose ; pour un lancement
# local, les exporter dans le shell avant `mvn spring-boot:run`.
# ─────────────────────────────────────────────────────────────

# Connexion PostgreSQL (format JDBC).
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/afb_titres
SPRING_DATASOURCE_USERNAME=afb_app
SPRING_DATASOURCE_PASSWORD=change_me_db

# Secret de signature JWT — OBLIGATOIRE, >= 32 caracteres aleatoires.
APP_JWT_SECRET=remplacer_par_un_secret_aleatoire_de_32_caracteres_minimum

# Durees de vie des jetons (secondes).
APP_ACCESS_TOKEN_TTL=900          # 15 min — jeton d'acces court
APP_REFRESH_TOKEN_TTL=2592000     # 30 jours — jeton de rafraichissement

# Origine autorisee pour le CORS (frontend Angular).
APP_FRONTEND_ORIGIN=http://localhost:4200

# Mode d'authentification a la plateforme :
#   LOCAL           = mot de passe verifie en base (defaut)
#   LDAP            = verification via LDAP / Active Directory (strict)
#   LDAP_THEN_LOCAL = annuaire pour les comptes AD, repli base sinon (hybride)
# L'annuaire se configure dans l'espace d'administration > LDAP / Active Directory.
APP_AUTH_MODE=LOCAL

# L'application ne contient AUCUNE donnee de demonstration : elle demarre sur une
# base vierge. Ce drapeau n'a plus d'effet (le jeu de donnees vit sous src/test et
# n'est jamais empaquete) ; il ne subsiste que pour les tests.
APP_SEED_ON_START=false

# ── Premier demarrage : administrateur initial ────────────────────────────────
# Sur une base VIERGE, aucun compte n'existe : personne ne pourrait se connecter
# pour creer les autres. Renseignez ces deux variables au tout premier demarrage,
# connectez-vous, puis RETIREZ-LES. Le mot de passe devra etre change a la
# premiere connexion, et n'est jamais journalise.
# Sans effet des que la base compte au moins un utilisateur : cet amorcage ne peut
# donc pas servir a s'octroyer un acces sur une plateforme en service.
APP_BOOTSTRAP_ADMIN_EMAIL=
APP_BOOTSTRAP_ADMIN_PASSWORD=

# Code OTP fixe pour la MFA en developpement (6 chiffres).
# Laisser VIDE / supprimer en production : la MFA utilise alors un code
# aleatoire a usage unique, envoye par SMS/e-mail et journalise cote serveur.
APP_MFA_DEV_CODE=123456

# Port d'ecoute du serveur.
# Adresse d'écoute du serveur
BIND_ADDR=0.0.0.0:8080
